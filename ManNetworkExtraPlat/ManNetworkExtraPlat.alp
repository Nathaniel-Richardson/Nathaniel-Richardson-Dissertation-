						<Name><![CDATA[firstStop]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[if (firstStop.equals("Man Piccadilly")) return trainSourcePicc;
if (firstStop.equals("Man Oxford Rd")) return trainSourceOxf;
if (firstStop.equals("Water St Jn")) return trainSourceWatIrw;
if (firstStop.equals("Irwell Bridge Jn")) return trainSourceWatIrw;
if (firstStop.equals("Salford Central")) return trainSourceSal;
if (firstStop.equals("Castlefield Jn")) return trainSourceCas;
if (firstStop.equals("Man Victoria")) return trainSourceVic;
return trainSourcePicc;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[PositionOnTrack]]></ReturnType>
					<Id>1774981778980</Id>
					<Name><![CDATA[getTargetNode]]></Name>
					<X>40</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[train]]></Name>
						<Type><![CDATA[Train]]></Type>
					</Parameter>
					<Body><![CDATA[String stationName = train.stops.get(train.stopIndex).split("\\|")[1];
String lastStop = train.stops.get(train.stops.size() - 1).split("\\|")[1];

PositionOnTrack target;

// Deal St Jn down - Salford branch FIRST
if (stationName.equals("Deal St Jn") && train.direction.equals("down") 
           && lastStop.equals("Salford Central")) {
    if (train.platformChoice == null) {
        ArrayList<PositionOnTrack> salDownOptions = new ArrayList<>();
        salDownOptions.add(DealSt3);
        salDownOptions.add(DealSt5);
        train.platformChoice = getFreePlatform(salDownOptions);
        if (train.platformChoice == DealSt5) {
            train.routePath = "deal5";
        } else {
            train.routePath = "deal3";
        }
    }
    target = train.platformChoice;

// Deal St Jn down - main line trains SECOND
} else if (stationName.equals("Deal St Jn") && train.direction.equals("down")) {
    if (train.platformChoice == null) {
        train.platformChoice = DealSt3;
        platformOccupied.put(DealSt3, true);
        train.routePath = "deal3";
    }
    target = train.platformChoice;
    
// VicW down - options depend on which Deal St track was used
} else if (stationName.equals("Man Vic Jn (W)") && train.direction.equals("down")) {
    if (train.platformChoice == null) {
        ArrayList<PositionOnTrack> vicWOptions = new ArrayList<>();
        if (train.routePath.equals("deal5")) {
            vicWOptions.add(VicW4);
            vicWOptions.add(VicW5);
        } else {
            // deal3 can reach vicW 3/4/5
            vicWOptions.add(VicW3);
            vicWOptions.add(VicW4);
            vicWOptions.add(VicW5);
        }
        train.platformChoice = getFreePlatform(vicWOptions);
        // update routePath for Victoria selection
        if (train.platformChoice == VicW3) train.routePath = "vicW3";
        else if (train.platformChoice == VicW4) train.routePath = "vicW4";
        else train.routePath = "vicW5";
    }
    target = train.platformChoice;

// Victoria down - options depend on VicW track
} else if (stationName.equals("Man Victoria") && train.direction.equals("down")) {
    if (train.platformChoice == null) {
        if (train.routePath.equals("vicW3")) {
            if (!platformOccupied.get(SignalDvic4)) {
                train.platformChoice = SignalDvic4;
            } else {
                train.platformChoice = SignalDvic5;
            }
        } else if (train.routePath.equals("vicW4")) {
            train.platformChoice = SignalDvic5;
        } else {
            train.platformChoice = SignalDvic6;
        }
        platformOccupied.put(train.platformChoice, true);
    }
    target = train.platformChoice;
    
// Deal St Jn up
} else if (stationName.equals("Deal St Jn") && train.direction.equals("up")) {
    if (train.platformChoice == null) {
        if (lastStop.equals("Salford Central")) {
            ArrayList<PositionOnTrack> salfordOptions = new ArrayList<>();
            salfordOptions.add(DealSt2);
            salfordOptions.add(DealSt3);
            salfordOptions.add(DealSt4);
            salfordOptions.add(DealSt5);
            train.platformChoice = getFreePlatform(salfordOptions);
        } else {
            train.platformChoice = DealSt1;
            platformOccupied.put(DealSt1, true);
        }
    }
    target = train.platformChoice;

// VicW up - spawning trains come from SignalUvic3, can reach VicW2
} else if (stationName.equals("Man Vic Jn (W)") && train.direction.equals("up")) {
    if (train.platformChoice == null) {
        train.platformChoice = VicW2;
        platformOccupied.put(VicW2, true);
    }
    target = train.platformChoice;

} else if (stationName.equals("Man Oxford Rd") && train.direction.equals("down")) {
    if (train.platformChoice == null) {
        if (train.stops.get(0).split("\\|")[1].equals("Man Oxford Rd")) {
            // Train spawned at Oxford Rd - use spawn platform signal
            train.platformChoice = SignalDoxf5;
            platformOccupied.put(SignalDoxf5, true);
        } else {
            train.platformChoice = getFreePlatform(oxfDownPlatforms);
        }
    }
    target = train.platformChoice;

} else if (stationName.equals("Man Oxford Rd") && train.direction.equals("up")) {
    if (train.platformChoice == null) {
        if (lastStop.equals("Man Oxford Rd")) {
            train.platformChoice = SignalUoxf5;
            platformOccupied.put(SignalUoxf5, true);
        } else {
            train.platformChoice = getFreePlatform(oxfUpPlatforms);
        }
    }
    target = train.platformChoice;
    
} else if (stationName.equals("Salford Central") && train.direction.equals("up")) {
    if (lastStop.equals("Salford Central")) {
        target = SignalU13;
    } else {
        target = SignalU10;
    }

} else if (stationName.equals("Salford Central") && train.direction.equals("down")) {
    if (train.stops.get(0).split("\\|")[1].equals("Salford Central")) {
        // Train spawned at Salford Central - use branch platform signal
        target = SignalD19;
    } else {
        // Train arriving from mainline
        target = getNodeDown("Salford Central");
    }


} else if (stationName.equals("Irwell Bridge Jn") && train.direction.equals("down")) {
    if (train.stops.get(0).split("\\|")[1].equals("Irwell Bridge Jn")) {
        // Train spawned at Irwell Bridge Jn - use spawn signal
        target = Irwell3;
    } else {
        // Mainline train passing through
        target = Irwell2;
    }

} else if (stationName.equals("Man Piccadilly") && train.direction.equals("up")) {
    if (train.platformChoice == null) {
        train.platformChoice = getFreePlatform(piccUpPlatforms);
    }
    target = train.platformChoice;

} else if (train.direction.equals("down")) {
    target = getNodeDown(stationName);
    
} else {
    target = getNodeUp(stationName);
}

traceln(train.trainID + " Departs to " + stationName + "| time: " + time());
return target;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1775148320935</Id>
					<Name><![CDATA[exportResults]]></Name>
					<X>-240</X><Y>120</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[try {
    java.io.FileWriter fw = new java.io.FileWriter("C:/Users/Nathaniel/Desktop/results_.txt");
    java.io.BufferedWriter bw = new java.io.BufferedWriter(fw);
    bw.write("station|trainsPerHour|note");
    bw.newLine();
    for (String entry : delayLog) {
        bw.write(entry);
        bw.newLine();
    }
    // Summary block
	bw.newLine();
	bw.write("=== THROUGHPUT SUMMARY ===");
	bw.newLine();
	bw.write("station|trainsPerHour|minHeadway|avgHeadway|maxHeadway");
	bw.newLine();
	
	// Station-level totals (trainsPerHour still by station)
	for (String station : throughputCount.keySet()) {
	    int count = throughputCount.get(station);
	    bw.write(station + "|" + count + "|per_track_below");
	    bw.newLine();
	}
	
	bw.newLine();
	bw.write("station|track|minHeadway|avgHeadway|maxHeadway|trainCount");
	bw.newLine();
	
	// Track-level headway breakdown
	for (String key : headwayCount.keySet()) {
	    int count = headwayCount.get(key);
	    double min = headwayMin.containsKey(key) ? headwayMin.get(key) : -1;
	    double max = headwayMax.containsKey(key) ? headwayMax.get(key) : -1;
	    double avg = count > 0 ? headwaySum.get(key) / count : -1;
	    bw.write(key + "|" + min + "|" + avg + "|" + max + "|" + count);
	    bw.newLine();
	}
		
	bw.newLine();
	bw.write("=== HEADWAY WARNINGS ===");
	bw.newLine();
	for (String entry : delayLog) {
	    if (entry.startsWith("HEADWAY_WARN")) {
	        bw.write(entry);
	        bw.newLine();
	    }
	}
    bw.close();
    traceln("Results exported successfully");
} catch (Exception e) {
    traceln("Export error: " + e.getMessage());
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[PositionOnTrack]]></ReturnType>
					<Id>1775150663506</Id>
					<Name><![CDATA[getFreePlatform]]></Name>
					<X>40</X><Y>670</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[options]]></Name>
						<Type><![CDATA[ArrayList<PositionOnTrack>]]></Type>
					</Parameter>
					<Body><![CDATA[for (Object obj : options) {
    PositionOnTrack p = (PositionOnTrack) obj;
    if (platformOccupied.containsKey(p) && !platformOccupied.get(p)) {
        platformOccupied.put(p, true);
        return p;
    }
}
// fallback if all occupied
PositionOnTrack first = (PositionOnTrack) options.get(0);
platformOccupied.put(first, true);
return first;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1775480456807</Id>
					<Name><![CDATA[shouldStopAtStation]]></Name>
					<X>-240</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[stopEntry]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[String[] parts = stopEntry.split("\\|");
String stationName = parts[1];
String arrivalTime = parts.length > 4 ? parts[4] : "";

if (stationName.equals("Man Piccadilly") ||
    stationName.equals("Man Oxford Rd") ||
    stationName.equals("Man Victoria")) {
    return true;
}

if (stationName.equals("Deansgate") ||
    stationName.equals("Salford Central")) {
    return !arrivalTime.isEmpty();
}

return false;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[String]]></ReturnType>
					<Id>1775738084811</Id>
					<Name><![CDATA[getMeasurementKey]]></Name>
					<X>-240</X><Y>300</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[pos]]></Name>
						<Type><![CDATA[PositionOnTrack]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[direction]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[// Piccadilly
if (pos == SignalDpic2) return "Piccadilly Down";
if (pos == SignalUpic2) return "Piccadilly Up";

// Between Piccadilly and Oxford Rd - dropped, no sensor
// Oxford Rd
if (pos == SignalDoxf1) return "Oxford Rd Down P1";
if (pos == SignalDoxf3) return "Oxford Rd Down P3";
if (pos == SignalUoxf1L) return "Oxford Rd Up P1";
if (pos == SignalUoxf3) return "Oxford Rd Up P3";

// Deansgate
if (pos == SignalD9) return "Deansgate Down";
if (pos == SignalU23) return "Deansgate Up";

// Castlefield
if (pos == Cas1) return "Castlefield Up";
if (pos == Cas2) return "Castlefield Down";

// Water St
if (pos == Water1) return "Water St Up";
if (pos == Water2) return "Water St Down";

// Irwell
if (pos == Irwell1) return "Irwell Up";
if (pos == Irwell2) return "Irwell Down";
if (pos == Irwell3) return "Irwell P3";

// Salford Central
if (pos == SignalD19) return "Salford Down Main";
if (pos == SignalD21) return "Salford Down Branch";
if (pos == SignalU10) return "Salford Up Main";
if (pos == SignalU11) return "Salford Up Extra";
if (pos == SignalU13) return "Salford Up Branch";

// Deal St
if (pos == DealSt1) return "Deal St P1";
if (pos == DealSt2) return "Deal St P2";
if (pos == DealSt3) return "Deal St P3";
if (pos == DealSt4) return "Deal St P4";
if (pos == DealSt5) return "Deal St P5";

// Vic W
if (pos == VicW1) return "Vic W P1";
if (pos == VicW2) return "Vic W P2";
if (pos == VicW3) return "Vic W P3";
if (pos == VicW4) return "Vic W P4";
if (pos == VicW5) return "Vic W P5";

// Victoria
if (pos == SignalDvic4) return "Victoria P4";
if (pos == SignalDvic5) return "Victoria P5";
if (pos == SignalDvic6) return "Victoria P6";
if (pos == SignalUvic3) return "Victoria Up";

return "Unknown";]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1775738145352</Id>
					<Name><![CDATA[logHeadway]]></Name>
					<X>-240</X><Y>320</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[pos]]></Name>
						<Type><![CDATA[PositionOnTrack]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[trainID]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[direction]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[currentTime]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[String key = getMeasurementKey(pos, direction);
if (key.equals("Unknown")) return;

// Throughput
if (throughputCount.containsKey(key)) {
    throughputCount.put(key, throughputCount.get(key) + 1);
} else {
    throughputCount.put(key, 1);
}

// Headway calculation
double headway = -1;
if (lastPassTime.containsKey(key)) {
    headway = currentTime - lastPassTime.get(key);
    String lastDir = lastPassDirection.getOrDefault(key, "");

    // Update stats
    if (!headwayMin.containsKey(key) || headway < headwayMin.get(key)) {
        headwayMin.put(key, headway);
    }
    if (!headwayMax.containsKey(key) || headway > headwayMax.get(key)) {
        headwayMax.put(key, headway);
    }
    headwaySum.put(key, headwaySum.getOrDefault(key, 0.0) + headway);
    headwayCount.put(key, headwayCount.getOrDefault(key, 0) + 1);

    // Warn if short headway
    if (headway < 2.0 && headway > 0) {
        delayLog.add("HEADWAY_WARN|" + key + "|" + trainID + "|" + headway);
    }

    // Flag opposite direction
    if (!lastDir.equals("") && !lastDir.equals(direction)) {
        delayLog.add("OPPOSITE_DIR|" + key + "|" + trainID + "|" + direction + 
                     "|prev:" + lastDir + "|headway:" + headway);
    }
}

lastPassTime.put(key, currentTime);
lastPassDirection.put(key, direction);
delayLog.add(trainID + "|" + key + "|headway|" + headway);]]></Body>
				</Function>
