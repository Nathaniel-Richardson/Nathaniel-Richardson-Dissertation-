		<ActiveObjectClass>
			<Id>1770226971069</Id>
			<Name><![CDATA[Manchester]]></Name>
			<StartupCode><![CDATA[schedule = new ArrayList<String>();
scheduleByTrain = new LinkedHashMap<String, ArrayList<String>>();

String[] stations = {
    "Man Piccadilly", "Man Oxford Rd", "Deansgate", "Castlefield Jn",
    "Water St Jn", "Irwell Bridge Jn", "Salford Central", "Deal St Jn",
    "Man Vic Jn (W)", "Man Victoria"
};

for (int i = 4; i <= 24; i++) {
    String trainID = train_timings_07mar2026.getCellStringValue("Train Timings 1200-1500", i, 2);
    if (trainID == null || trainID.trim().isEmpty()) continue;
    trainID = trainID.trim();

    for (int col = 6; col <= 15; col++) {
        String stationName = stations[col - 6];
        String depTime;
        try {
            depTime = train_timings_07mar2026.getCellStringValue("Train Timings 1200-1500", i, col);
        } catch (Exception e) {
            double numVal = train_timings_07mar2026.getCellNumericValue("Train Timings 1200-1500", i, col);
            int h = (int) numVal / 100;
            int m = (int) numVal % 100;
            depTime = String.format("%02d%02d", h, m);
        }

        if (depTime == null || depTime.trim().isEmpty() || depTime.equals("—") || depTime.equals("-")) continue;
        depTime = depTime.trim();

        // Map station name to arrival time column (P=16, Q=17, R=18, S=19, T=20)
		LinkedHashMap<String, Integer> arrivalCols = new LinkedHashMap<String, Integer>();
		arrivalCols.put("Man Piccadilly", 16);
		arrivalCols.put("Man Oxford Rd", 17);
		arrivalCols.put("Deansgate", 18);
		arrivalCols.put("Salford Central", 19);
		arrivalCols.put("Man Victoria", 20);
		
		String arrivalTime = "";
		if (arrivalCols.containsKey(stationName)) {
		    try {
		        String arrCell = train_timings_07mar2026.getCellStringValue("Train Timings 1200-1500", i, arrivalCols.get(stationName));
		        if (arrCell != null && !arrCell.trim().isEmpty() && !arrCell.equals("—") && !arrCell.equals("-")) {
		            arrivalTime = arrCell.trim();
		        }
		    } catch (Exception e) {
		        try {
		            double numVal = train_timings_07mar2026.getCellNumericValue("Train Timings 1200-1500", i, arrivalCols.get(stationName));
		            int h = (int) numVal / 100;
		            int m = (int) numVal % 100;
		            arrivalTime = String.format("%02d%02d", h, m);
		        } catch (Exception e2) {
		            arrivalTime = "";
		        }
		    }
		}
		
		double modelTime = timeToMinutes(depTime);
		String entry = trainID + "|" + stationName + "|" + depTime + "|" + modelTime + "|" + arrivalTime;
		schedule.add(entry);

        if (!scheduleByTrain.containsKey(trainID)) {
            scheduleByTrain.put(trainID, new ArrayList<String>());
        }
        scheduleByTrain.get(trainID).add(entry);
    }
}

for (int i = 64; i <= 79; i++) {
    String trainID = train_timings_07mar2026.getCellStringValue("Train Timings 1200-1500", i, 2);
    if (trainID == null || trainID.trim().isEmpty()) continue;
    trainID = trainID.trim();

    for (int col = 6; col <= 15; col++) {
        String stationName = stations[col - 6];
        String depTime;
        try {
            depTime = train_timings_07mar2026.getCellStringValue("Train Timings 1200-1500", i, col);
        } catch (Exception e) {
            double numVal = train_timings_07mar2026.getCellNumericValue("Train Timings 1200-1500", i, col);
            int h = (int) numVal / 100;
            int m = (int) numVal % 100;
            depTime = String.format("%02d%02d", h, m);
        }

        if (depTime == null || depTime.trim().isEmpty() || depTime.equals("—") || depTime.equals("-")) continue;
        depTime = depTime.trim();

        // Map station name to arrival time column (P=16, Q=17, R=18, S=19, T=20)
		LinkedHashMap<String, Integer> arrivalCols = new LinkedHashMap<String, Integer>();
		arrivalCols.put("Man Piccadilly", 16);
		arrivalCols.put("Man Oxford Rd", 17);
		arrivalCols.put("Deansgate", 18);
		arrivalCols.put("Salford Central", 19);
		arrivalCols.put("Man Victoria", 20);
		
		String arrivalTime = "";
		if (arrivalCols.containsKey(stationName)) {
		    try {
		        String arrCell = train_timings_07mar2026.getCellStringValue("Train Timings 1200-1500", i, arrivalCols.get(stationName));
		        if (arrCell != null && !arrCell.trim().isEmpty() && !arrCell.equals("—") && !arrCell.equals("-")) {
		            arrivalTime = arrCell.trim();
		        }
		    } catch (Exception e) {
		        try {
		            double numVal = train_timings_07mar2026.getCellNumericValue("Train Timings 1200-1500", i, arrivalCols.get(stationName));
		            int h = (int) numVal / 100;
		            int m = (int) numVal % 100;
		            arrivalTime = String.format("%02d%02d", h, m);
		        } catch (Exception e2) {
		            arrivalTime = "";
		        }
		    }
		}
		
		double modelTime = timeToMinutes(depTime);
		String entry = trainID + "|" + stationName + "|" + depTime + "|" + modelTime + "|" + arrivalTime;
		schedule.add(entry);

        if (!scheduleByTrain.containsKey(trainID)) {
            scheduleByTrain.put(trainID, new ArrayList<String>());
        }
        scheduleByTrain.get(trainID).add(entry);
    }
}

traceln("Total schedule entries: " + schedule.size());
traceln("Total trains: " + scheduleByTrain.size());

// --- Dynamic spawn events for all trains ---
for (String tid : scheduleByTrain.keySet()) {
    ArrayList<String> stops = scheduleByTrain.get(tid);
    if (stops.isEmpty()) continue;

    pendingIDs.add(tid);
    pendingStops.add(stops);
}
for (String tid : scheduleByTrain.keySet()) {
    ArrayList<String> stops = scheduleByTrain.get(tid);
    if (stops.size() < 2) continue;
    
    double firstTime = Double.parseDouble(stops.get(0).split("\\|")[3]);
    double lastTime = Double.parseDouble(stops.get(stops.size()-1).split("\\|")[3]);
    
    String direction = (lastTime > firstTime) ? "down" : "up";
    trainDirections.put(tid, direction);
    
    if (direction.equals("up")) {
        java.util.Collections.reverse(stops);
        scheduleByTrain.put(tid, stops);
    }
    
    traceln(tid + " direction: " + direction + " | first stop: " + stops.get(0).split("\\|")[1] + " at " + stops.get(0).split("\\|")[2]);
}
oxfDownPlatforms.add(SignalDoxf1);
oxfDownPlatforms.add(SignalDoxf3);

oxfUpPlatforms.add(SignalUoxf1L);
oxfUpPlatforms.add(SignalUoxf3);

piccUpPlatforms.add(SignalUpic2);
piccUpPlatforms.add(SignalUpic15);

vicDownPlatforms.add(SignalDvic4);
vicDownPlatforms.add(SignalDvic5);
vicDownPlatforms.add(SignalDvic6);

dealStTracks.add(DealSt1);
dealStTracks.add(DealSt2);
dealStTracks.add(DealSt3);
dealStTracks.add(DealSt4);
dealStTracks.add(DealSt5);

vicWTracks.add(VicW1);
vicWTracks.add(VicW2);
vicWTracks.add(VicW3);
vicWTracks.add(VicW4);
vicWTracks.add(VicW5);

platformOccupied.put(SignalUpic2, false);
platformOccupied.put(SignalUpic15, false);
platformOccupied.put(SignalDoxf1, false);
platformOccupied.put(SignalDoxf3, false);
platformOccupied.put(SignalUoxf1L, false);
platformOccupied.put(SignalUoxf3, false);
platformOccupied.put(SignalDvic4, false);
platformOccupied.put(SignalDvic6, false);
platformOccupied.put(DealSt1, false);
platformOccupied.put(DealSt2, false);
platformOccupied.put(DealSt3, false);
platformOccupied.put(DealSt4, false);
platformOccupied.put(DealSt5, false);
platformOccupied.put(VicW1, false);
platformOccupied.put(VicW2, false);
platformOccupied.put(VicW3, false);
platformOccupied.put(VicW4, false);
platformOccupied.put(VicW5, false);]]></StartupCode>
