				<EmbeddedObject>
					<Id>1774362257919</Id>
					<Name><![CDATA[waitAtStop]]></Name>
					<X>560</X><Y>80</Y>
					<Label><X>0</X><Y>-15</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Delay]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Delay]]></ClassName>
							<ItemName><![CDATA[1412336242930]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[type]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[delayTime]]></Name>
							<Value Class="CodeUnitValue">
								<Code><![CDATA[shouldStopAtStation(((Train)agent).stops.get(((Train)agent).stopIndex)) 
    ? Math.max(0, Double.parseDouble(((Train)agent).stops.get(((Train)agent).stopIndex).split("\\|")[3]) - time())
    : 0.0]]></Code>
								<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[capacity]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[100]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[maximumCapacity]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[entityLocation]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[pushProtocol]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[restoreEntityLocationOnExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[false]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[forceStatisticsCollection]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Train t = (Train)agent;
String stationName = t.stops.get(t.stopIndex).split("\\|")[1];
double scheduledTime = timeToMinutes(t.stops.get(t.stopIndex).split("\\|")[2]);
double actualTime = time();
double arrivalDelay = actualTime - scheduledTime;

traceln(t.trainID + " ARRIVED at " + stationName + " at model time " + actualTime);

// Throughput counter
if (throughputCount.containsKey(stationName)) {
    throughputCount.put(stationName, throughputCount.get(stationName) + 1);
} else {
    throughputCount.put(stationName, 1);
}

// Build track-specific key
String trackKey;
if (t.platformChoice != null) {
    trackKey = stationName + "|" + t.platformChoice.toString();
} else {
    trackKey = stationName + "|" + t.direction;
}

// Headway logging - always runs regardless of stop index
double headway = -1;
if (lastPassTime.containsKey(trackKey)) {
    headway = actualTime - lastPassTime.get(trackKey);

    // Update min
    if (!headwayMin.containsKey(trackKey) || headway < headwayMin.get(trackKey)) {
        headwayMin.put(trackKey, headway);
    }
    // Update max
    if (!headwayMax.containsKey(trackKey) || headway > headwayMax.get(trackKey)) {
        headwayMax.put(trackKey, headway);
    }
    // Sum and count for average
    headwaySum.put(trackKey, headwaySum.getOrDefault(trackKey, 0.0) + headway);
    headwayCount.put(trackKey, headwayCount.getOrDefault(trackKey, 0) + 1);

    // Warn if headway below 2 minutes
    if (headway < 2.0 && headway > 0) {
        delayLog.add("HEADWAY_WARN|" + stationName + "|" + t.trainID + "|track:" + trackKey + "|" + headway);
    }
}
lastPassTime.put(trackKey, actualTime);
delayLog.add(t.trainID + "|" + stationName + "|headway|" + trackKey + "|" + headway);

// Arrival delay - exclude first stop to avoid spawn artefact
if (t.stopIndex > 0) {
    delayLog.add(t.trainID + "|" + stationName + "|" + scheduledTime + 
                 "|" + actualTime + "|" + arrivalDelay);
} else {
    delayLog.add(t.trainID + "|" + stationName + "|SPAWN_EXCLUDED|" + 
                 actualTime + "|N/A");
}]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onAtExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Train t = (Train)agent;
String stationName = t.stops.get(t.stopIndex).split("\\|")[1];

if (stationName.equals("Man Oxford Rd") || 
    stationName.equals("Man Victoria") ||
    stationName.equals("Man Piccadilly") ||
    stationName.equals("Deal St Jn") ||
    stationName.equals("Man Vic Jn (W)")) {
    if (t.platformChoice != null) {
        platformOccupied.put(t.platformChoice, false);
        t.platformChoice = null;
    }
}
t.stopIndex++;
if (t.stopIndex >= t.stops.size()) {
    traceln(t.trainID + " completed journey at time " + time());
}]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
						</Parameter>
