					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<Id>1774536269293</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1774598400000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (int i = pendingIDs.size() - 1; i >= 0; i--) {
    double spawnTime = Double.parseDouble(
        ((ArrayList<String>)pendingStops.get(i)).get(0).split("\\|")[3]
    ) - 0.5;
    if (time() >= spawnTime) {
        String tid = pendingIDs.remove(i);
        ArrayList<String> stops = (ArrayList<String>) pendingStops.remove(i);
        String firstStop = stops.get(0).split("\\|")[1];
        ((TrainSource) getTrainSource(firstStop)).inject();
        Train t = (Train) trains.get(trains.size() - 1);
        t.trainID = tid;
        t.direction = trainDirections.get(tid);
        t.stops = stops;
        t.stopIndex = 0;
    }
}]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1774281151067</Id>
					<Name><![CDATA[timeToMinutes]]></Name>
					<X>40</X><Y>330</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[timeStr]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[timeStr = timeStr.replace("½", ".5");
int hours = Integer.parseInt(timeStr.substring(0, 2));
int mins = Integer.parseInt(timeStr.substring(2, 4));
double secs = timeStr.contains(".") ? 30 : 0;
double totalMins = hours * 60 + mins + secs/60;
return totalMins - (11 * 60 + 55); // subtract model start time 11:55]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
